// For format details, see https://aka.ms/devcontainer.json.
// {{SETUP}} Lies DOMAIN.md für Hinweise zu den Anpassungen, bevor du dieses File änderst.
{
"$schema": "./devcontainer.schema.json",
"name": "KI",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-community/npm-features/prettier:1": {},
    "ghcr.io/devcontainers-extra/features/zsh-plugins:0": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers-extra/features/ripgrep:1": {}
  },
  // Ports nach Bedarf anpassen oder entfernen
  "forwardPorts": [
    8080,
    8081,
    4200
  ],
  "mounts": [
    // Named-Volume-Cache für Maven — überleben Container-Rebuilds
    "source=localcache,target=/home/vscode/.m2,type=volume",
    // Vertex Service Account vom Host einbinden (Variante B: localEnv)
    "source=${localEnv:HOME}/.config/gcp/vertex-service-account.json,target=/home/vscode/.config/gcp/vertex-service-account.json,type=bind,readonly"
  ],
"postCreateCommand": ".devcontainer/scripts/postCreateCommand.sh",
  "remoteEnv": {
    "DOCKER_NETWORK": "docker-default-network",
    // npm-Mirror (Verdaccio) — entfernen wenn kein lokaler npm-Mirror
    "NPM_MIRROR": "npm-mirror:4873",
    // Local LLM endpoints (optional)
    "LMSTUDIO": "http://192.168.64.1:1234",
    "MLX_SERVER": "http://192.168.64.1:1234",
    // Claude via Google Vertex AI
    "CLAUDE_CODE_USE_VERTEX": "1",
    "GOOGLE_APPLICATION_CREDENTIALS": "/home/vscode/.config/gcp/vertex-service-account.json",
    "ANTHROPIC_VERTEX_PROJECT_ID": "${localEnv:GCP_PROJECT_ID:usergroups-490009}",
    "CLOUD_ML_REGION": "${localEnv:GCP_REGION:europe-west1}",
    "ANTHROPIC_VERTEX_REGION": "${localEnv:GCP_REGION:europe-west1}",
    "ANTHROPIC_MODEL": "claude-sonnet-4-6"
  },
  "initializeCommand": "touch .env && mkdir -p ${localEnv:HOME}/.vscode && touch ${localEnv:HOME}/.vscode/.zsh_history && (docker network inspect docker-default-network >/dev/null 2>&1 || docker network create docker-default-network >/dev/null)",
  "runArgs": [
    "--network=docker-default-network",
    "--env-file=${localWorkspaceFolder}/.env",
    "--hostname=${localWorkspaceFolderBasename}"
  ],
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "customizations": {
    "vscode": {
      // Kernerweiterungen — projektunabhängig
      "extensions": [
        "ms-azuretools.vscode-docker",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "waderyan.gitblame",
        "timonwong.shellcheck",
        "yzhang.markdown-all-in-one",
        "redhat.vscode-yaml",
        "EditorConfig.EditorConfig",
        "vstirbu.vscode-mermaid-preview",
        "Continue.continue",
        "ms-playwright.playwright",
        "anthropic.claude-code",
        // Java/Maven (entfernen wenn kein Java)
        "vscjava.vscode-java-pack",
        "vscjava.vscode-java-test",
        "redhat.java",
        "shengchen.vscode-checkstyle",
        "SonarSource.sonarlint-vscode",
        "DotJoshJohnson.xml",
        "redhat.vscode-xml",
        // Angular (entfernen wenn kein Angular)
        "Angular.ng-template",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh"
          }
        },
        "editor.formatOnSave": true,
        "editor.cursorBlinking": "solid"
      }
    }
  }
}
